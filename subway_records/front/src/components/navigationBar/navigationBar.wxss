/* 导航栏组件样式 */
.navigation-bar {
  display: flex;
  align-items: center;
  height: 88rpx;
  padding: 0 20rpx;
  position: relative;
}

.nav-left, .nav-right {
  width: 80rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.back-icon, .more-icon {
  font-size: 48rpx;
  font-weight: bold;
}

.nav-center {
  flex: 1;
  display: flex;
  justify-content: center;
  align-items: center;
}

.nav-title {
  font-size: 36rpx;
  font-weight: bold;
}