/* 首页样式 */
.user-info {
  display: flex;
  flex-direction: column;
  align-items: center;
  text-align: center;
}

.avatar {
  width: 120rpx;
  height: 120rpx;
  border-radius: 60rpx;
  margin-bottom: 20rpx;
}

.username {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 10rpx;
}

.streak {
  font-size: 28rpx;
  color: #666;
}

.checkin-area {
  text-align: center;
}

.location-info {
  margin-bottom: 40rpx;
}

.location-title {
  font-size: 32rpx;
  color: #333;
  display: block;
  margin-bottom: 10rpx;
}

.station-name {
  font-size: 40rpx;
  font-weight: bold;
  color: #1976D2;
}

.checkin-time {
  font-size: 48rpx;
  font-weight: bold;
  margin-bottom: 10rpx;
}

.checkin-text {
  font-size: 36rpx;
}

.stats-area {
  text-align: center;
}

.stats-grid {
  display: flex;
  justify-content: space-around;
  margin-top: 20rpx;
}

.stat-item {
  text-align: center;
}

.stat-number {
  font-size: 48rpx;
  font-weight: bold;
  color: #1976D2;
  display: block;
}

.stat-label {
  font-size: 28rpx;
  color: #666;
}

.recent-stations .title {
  margin-bottom: 20rpx;
}

.stations-scroll {
  width: 100%;
  white-space: nowrap;
}

.station-list {
  display: inline-flex;
}

.station-card {
  width: 200rpx;
  margin-right: 20rpx;
  text-align: center;
  background-color: #f9f9f9;
  border-radius: 10rpx;
  padding: 20rpx;
}

.station-image {
  width: 160rpx;
  height: 120rpx;
  border-radius: 10rpx;
  margin-bottom: 10rpx;
}

.station-name {
  font-size: 28rpx;
  color: #333;
  display: block;
  margin-bottom: 5rpx;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.station-rating {
  font-size: 24rpx;
  color: #FF9500;
}