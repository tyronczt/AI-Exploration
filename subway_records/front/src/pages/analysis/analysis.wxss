/* 分析页面样式 */
.stats-cards {
  display: flex;
  justify-content: space-between;
  margin-bottom: 20rpx;
}

.stat-card {
  flex: 1;
  margin: 0 10rpx;
  text-align: center;
  padding: 30rpx 20rpx;
}

.stat-title {
  font-size: 28rpx;
  color: #666;
  margin-bottom: 10rpx;
}

.stat-value {
  font-size: 48rpx;
  font-weight: bold;
  color: #1976D2;
  display: block;
}

.stat-unit {
  font-size: 24rpx;
  color: #999;
}

.chart-section {
  margin-bottom: 20rpx;
}

.chart-container {
  height: 300rpx;
  display: flex;
  align-items: flex-end;
  justify-content: space-around;
  margin-top: 20rpx;
}

.chart-bar-container {
  display: flex;
  flex-direction: column;
  align-items: center;
  width: 12%;
}

.chart-bar {
  width: 100%;
  border-radius: 10rpx 10rpx 0 0;
}

.chart-label {
  font-size: 24rpx;
  color: #666;
  margin-top: 10rpx;
}

.route-list {
  margin-top: 20rpx;
}

.route-item {
  display: flex;
  align-items: center;
  margin-bottom: 20rpx;
}

.route-name {
  font-size: 28rpx;
  color: #333;
  width: 30%;
}

.route-bar-container {
  flex: 1;
  display: flex;
  align-items: center;
  margin-left: 20rpx;
}

.route-bar {
  height: 20rpx;
  border-radius: 10rpx;
}

.route-percentage {
  font-size: 24rpx;
  color: #666;
  margin-left: 10rpx;
  width: 50rpx;
  text-align: right;
}

.suggestion-list {
  margin-top: 20rpx;
}

.suggestion-item {
  padding: 20rpx;
  border-left: 4rpx solid #1976D2;
  background-color: #e3f2fd;
  margin-bottom: 20rpx;
  border-radius: 0 10rpx 10rpx 0;
}

.suggestion-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #1976D2;
  display: block;
  margin-bottom: 10rpx;
}

.suggestion-content {
  font-size: 28rpx;
  color: #333;
  display: block;
  margin-bottom: 10rpx;
}

.suggestion-time {
  font-size: 24rpx;
  color: #999;
}