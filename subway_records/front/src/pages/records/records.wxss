/* 记录页面样式 */
.calendar-section {
  margin-bottom: 20rpx;
}

.calendar-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.calendar-title {
  font-size: 32rpx;
  font-weight: bold;
}

.calendar-nav {
  display: flex;
  align-items: center;
}

.nav-btn {
  background-color: transparent;
  border: none;
  font-size: 36rpx;
  padding: 0 20rpx;
}

.current-month {
  font-size: 32rpx;
  margin: 0 20rpx;
}

.weekdays {
  display: grid;
  grid-template-columns: repeat(7, 1fr);
  text-align: center;
  margin-bottom: 10rpx;
}

.weekday {
  font-size: 28rpx;
  color: #666;
  padding: 10rpx 0;
}

.days-grid {
  display: grid;
  grid-template-columns: repeat(7, 1fr);
  gap: 10rpx;
}

.day-cell {
  aspect-ratio: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  border-radius: 10rpx;
  position: relative;
}

.day-number {
  font-size: 28rpx;
  color: #333;
}

.day-cell.has-checkin {
  background-color: #e3f2fd;
}

.day-cell.today {
  background-color: #1976D2;
}

.day-cell.today .day-number {
  color: white;
}

.day-cell.other-month .day-number {
  color: #ccc;
}

.checkin-dot {
  width: 8rpx;
  height: 8rpx;
  background-color: #1976D2;
  border-radius: 50%;
  margin-top: 5rpx;
}

.records-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.selected-date {
  font-size: 28rpx;
  color: #666;
}

.record-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.record-item:last-child {
  border-bottom: none;
}

.record-info {
  flex: 1;
}

.record-time {
  font-size: 28rpx;
  color: #666;
  display: block;
  margin-bottom: 5rpx;
}

.record-status {
  font-size: 32rpx;
  color: #333;
  display: block;
  margin-bottom: 5rpx;
}

.record-location {
  font-size: 24rpx;
  color: #999;
}

.record-actions {
  display: flex;
  gap: 10rpx;
}

.edit-btn, .delete-btn {
  padding: 10rpx 20rpx;
  border-radius: 5rpx;
  font-size: 24rpx;
  border: none;
}

.edit-btn {
  background-color: #1976D2;
  color: white;
}

.delete-btn {
  background-color: #FF5722;
  color: white;
}

.empty-state {
  text-align: center;
  padding: 40rpx;
  color: #999;
}