<!--wordbook.wxml-->
<view class="container">
  <view class="header">
    <view class="title">载入卡包</view>
  </view>

  <!-- 加载状态 -->
  <view class="loading-overlay" wx:if="{{loading}}">
    <view class="loading-content">
      <view class="loading-spinner"></view>
      <view class="loading-text">{{loadingText}}</view>
    </view>
  </view>

  <view class="card-package-container" wx:if="{{!loading}}">
    <!-- 大包 -->
    <view class="package-section">
      <view class="section-title">大包</view>
      <view class="package-list">
        <view wx:for="{{bigPackages}}" wx:key="index" class="package-item {{selectedBigPackage === item ? 'active' : ''}}" bindtap="selectBigPackage" data-package="{{item}}">{{item}}</view>
      </view>
    </view>

    <!-- 小包 -->
    <view class="package-section">
      <view class="section-title">小包</view>
      <view class="package-list">
        <view wx:for="{{currentSmallPackages}}" wx:key="index" class="package-item {{selectedSmallPackage === item ? 'active' : ''}}" bindtap="selectSmallPackage" data-package="{{item}}">{{item}}</view>
      </view>
    </view>

    <!-- 卡包 -->
    <view class="package-section">
      <view class="section-title">卡包</view>
      <view class="package-list">
        <view wx:for="{{currentCardPackages}}" wx:key="index" class="package-item {{selectedCardPackage === item ? 'active' : ''}}" bindtap="selectCardPackage" data-package="{{item}}">{{item}}</view>
      </view>
    </view>
  </view>

  <view class="action-section" wx:if="{{!loading && selectedCardPackage}}">
    <button class="load-btn" bindtap="loadCardPackage">载入卡包</button>
  </view>
</view>