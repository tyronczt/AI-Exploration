/* wordbook.wxss */
.container {
  background-color: #e3f2fd;
  min-height: 100vh;
  padding: 0;
}

.header {
  padding: 30rpx 0;
  background-color: #4fc3f7;
}

.title {
  font-size: 36rpx;
  font-weight: bold;
  text-align: center;
  color: white;
}

/* 卡包容器 */
.card-package-container {
  display: flex;
  min-height: calc(100vh - 120rpx);
  background-color: white;
}

/* 包区域通用样式 */
.package-section {
  flex: 1;
  display: flex;
  flex-direction: column;
  border-right: 1rpx solid #f0f0f0;
}

.package-section:last-child {
  border-right: none;
}

/* 区域标题 */
.section-title {
  font-size: 24rpx;
  font-weight: bold;
  color: #333;
  padding: 20rpx;
  background-color: #f9f9f9;
  border-bottom: 1rpx solid #f0f0f0;
}

/* 包列表 */
.package-list {
  flex: 1;
  overflow-y: auto;
}

/* 包项 */
.package-item {
  padding: 25rpx 20rpx;
  font-size: 26rpx;
  color: #666;
  border-bottom: 1rpx solid #f0f0f0;
  transition: all 0.2s ease;
  position: relative;
  overflow: hidden;
}

.package-item:active {
  background-color: #f5f5f5;
  transform: translateX(5rpx);
}

.package-item.active {
  background-color: #e3f2fd;
  color: #4fc3f7;
  font-weight: bold;
  box-shadow: inset 4rpx 0 0 #4fc3f7;
  transform: translateX(5rpx);
}

.package-item::after {
  content: '';
  position: absolute;
  top: 0;
  left: -100%;
  width: 100%;
  height: 100%;
  background: linear-gradient(90deg, transparent, rgba(255,255,255,0.3), transparent);
  transition: left 0.5s;
}

.package-item:active::after {
  left: 100%;
}

/* 大包区域 */
.package-section:nth-child(1) {
  flex: 1.2;
}

/* 小包区域 */
.package-section:nth-child(2) {
  flex: 1.2;
}

/* 卡包区域 */
.package-section:nth-child(3) {
  flex: 2;
}

/* 操作区域 */
.action-section {
  position: fixed;
  bottom: 20rpx;
  left: 0;
  right: 0;
  padding: 0 40rpx;
  z-index: 100;
}

.load-btn {
  background-color: #4fc3f7;
  color: white;
  font-size: 32rpx;
  font-weight: bold;
  padding: 25rpx;
  border-radius: 60rpx;
  text-align: center;
  box-shadow: 0 4rpx 20rpx rgba(79, 195, 247, 0.3);
}

.load-btn:active {
  background-color: #29b6f6;
}

/* 滚动条样式 */
.package-list::-webkit-scrollbar {
  width: 4rpx;
}

.package-list::-webkit-scrollbar-track {
  background: #f1f1f1;
}

.package-list::-webkit-scrollbar-thumb {
  background: #c1c1c1;
  border-radius: 2rpx;
}

.package-list::-webkit-scrollbar-thumb:hover {
  background: #a1a1a1;
}

/* 加载状态 */
.loading-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(255, 255, 255, 0.8);
  display: flex;
  justify-content: center;
  align-items: center;
  z-index: 1000;
}

.loading-content {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 20rpx;
}

.loading-spinner {
  width: 60rpx;
  height: 60rpx;
  border: 4rpx solid #f3f3f3;
  border-top: 4rpx solid #4fc3f7;
  border-radius: 50%;
  animation: spin 1s linear infinite;
}

.loading-text {
  font-size: 28rpx;
  color: #666;
}

@keyframes spin {
  0% { transform: rotate(0deg); }
  100% { transform: rotate(360deg); }
}